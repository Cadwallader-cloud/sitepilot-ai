# Get your API key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here

# ── Crestis Simple Engine (default) ──────────────────────────────────────────
# Exactly 3 GPT calls on GPT-5 mini only:
#   1) Brand Personality → DNA JSON
#   2) Website Plan → Plan JSON
#   3) Generate Website JSON → copy + SEO + visual tokens
#
# Site generation always uses gpt-5-mini (full gpt-5 is remapped away).
# OPENAI_MODEL=gpt-5-mini
#
# Optional cheaper: gpt-5-nano
# OPENAI_MODEL=gpt-5-nano
#
# Full multi-layer engine (many GPT calls) — off by default:
# CRESTIS_ENGINE_DEEP=true
#
# Allow full gpt-5 / gpt-4o for site gen (not recommended at launch):
# CRESTIS_ALLOW_FULL_MODEL=true

# Live Unsplash/Pexels during generate — default OFF (uses curated local/CDN).
# CRESTIS_LIVE_STOCK_PHOTOS=true
# https://unsplash.com/oauth/applications
# UNSPLASH_ACCESS_KEY=your-unsplash-access-key
# https://www.pexels.com/api/
# PEXELS_API_KEY=your-pexels-api-key

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET=your-auth-secret-here

# Google OAuth — https://console.cloud.google.com/apis/credentials
AUTH_GOOGLE_ID=your-google-client-id.apps.googleusercontent.com
AUTH_GOOGLE_SECRET=your-google-client-secret

# Email login (6-digit code via Resend). Without this, email OTP only logs in dev.
# https://resend.com/api-keys
# AUTH_RESEND_KEY=re_xxxxxxxx
# AUTH_EMAIL_FROM=Crestis <login@crestis.app>
# Then run supabase/schema-auth.sql in the SQL Editor

# Production URL (Stripe redirects, OAuth)
# NEXT_PUBLIC_APP_URL=https://crestis.app

# Supabase — save generated site JSON as projects
# https://supabase.com/dashboard → Project Settings → API
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Then run supabase/schema.sql in the SQL Editor

# Stripe — add when ready for payments
# STRIPE_SECRET_KEY=sk_test_your-key-here

# Optional — Google Analytics & Meta Pixel for ads tracking
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_META_PIXEL_ID=123456789012345
